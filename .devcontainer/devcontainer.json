{
  "name": "Rust WASM Development Environment",
  // Microsoft公式のRust開発用ベースイメージを指定（Cargoが同梱されている）
  "image": "mcr.microsoft.com/devcontainers/rust:1-1-bookworm",

  // 拡張機能（Features）を使ってNode.jsをインストール
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },

  // wasm-packをビルドをスキップしてインストール
  "postCreateCommand": "curl https://rustwasm.github.io/wasm-pack/installer/init.sh -sSf | sh",

  // コンテナ実行時の一般ユーザーを指定
  "remoteUser": "vscode",

  // VS Code起動時に自動で入れておくと便利な拡張機能
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer", // Rustの強力な入力補完
        "fill-labs.dependi"        // Cargo.tomlの依存関係のバージョンチェック
      ]
    }
  }
}
